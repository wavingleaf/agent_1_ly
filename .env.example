# 将此文件复制为 .env 并填入实际值
# cp .env.example .env

OPENAI_API_KEY=sk-xxx
# 用 DeepSeek 等第三方 API 时需同时设置 OPENAI_BASE_URL
OPENAI_BASE_URL=https://api.deepseek.com
# 当前推荐 deepseek-v4-pro（Agent 任务开源 #1），也可用 deepseek-v4-flash（性价比）
# deepseek-chat 将于 2026-07-24 退役，届时返回错误
MODEL_NAME=deepseek-v4-pro

# DST 源码目录 —— grep/read_file/list_files 在此目录下执行文件操作。
# 从游戏安装目录的 scripts.zip 解压后得到，例如：
# DST_SOURCE_DIR=D:/Games/DST/scripts
DST_SOURCE_DIR=

# DST 元数据目录 —— dst_data_lookup 在此目录下读取结构化数据文件。
# 应包含 prefablist.lua / tuning.lua / chinese_s.po 三个文件。
# 例如：DST_META_DIR=D:/Github项目/mod流水线/github同步/命名、参数记录/DST本体
DST_META_DIR=

# DuckDuckGo 代理（中国大陆网络环境下需要，否则直连超时/返回空）
# Clash 默认端口: socks5h://127.0.0.1:7890
# 为空则直连搜索
DDG_PROXY=

# 思考模式深度：none（不思考）/ high（开启推理链）/ max（最强推理，token 消耗最大）
# 仅在 ChatDeepSeek 适配器下生效
REASONING_EFFORT=high